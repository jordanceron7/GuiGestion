import tkinter as tk
from tkinter import messagebox

class AppTareas:
    def __init__(self, root):
        self.root = root
        self.root.title("Gestor de Tareas")
        self.root.geometry("400x400")

        # Lista interna para guardar estado (texto, completado)
        self.tareas = []

        # Campo de entrada
        self.entry = tk.Entry(root, font=("Arial", 12))
        self.entry.pack(pady=10, padx=10, fill="x")

        # Lista de tareas
        self.lista = tk.Listbox(root, font=("Arial", 12), selectbackground="#a6a6a6")
        self.lista.pack(pady=10, padx=10, fill="both", expand=True)

        # Frame para botones
        frame_botones = tk.Frame(root)
        frame_botones.pack(pady=5)

        # Botones
        btn_add = tk.Button(frame_botones, text="Añadir", width=10, command=self.agregar_tarea)
        btn_add.grid(row=0, column=0, padx=5)

        btn_completar = tk.Button(frame_botones, text="Completar", width=10, command=self.completar_tarea)
        btn_completar.grid(row=0, column=1, padx=5)

        btn_eliminar = tk.Button(frame_botones, text="Eliminar", width=10, command=self.eliminar_tarea)
        btn_eliminar.grid(row=0, column=2, padx=5)

        # Atajos de teclado
        self.root.bind("<Return>", lambda event: self.agregar_tarea())
        self.root.bind("c", lambda event: self.completar_tarea())
        self.root.bind("<Delete>", lambda event: self.eliminar_tarea())
        self.root.bind("<Escape>", lambda event: self.root.quit())

    def agregar_tarea(self):
        texto = self.entry.get().strip()
        if texto == "":
            messagebox.showwarning("Aviso", "Escribe una tarea.")
            return
        
        # Guardamos como (texto, estado)
        self.tareas.append([texto, False])
        self.actualizar_lista()
        self.entry.delete(0, tk.END)

    def completar_tarea(self):
        try:
            indice = self.lista.curselection()[0]
            self.tareas[indice][1] = True
            self.actualizar_lista()
        except IndexError:
            messagebox.showwarning("Aviso", "Selecciona una tarea.")

    def eliminar_tarea(self):
        try:
            indice = self.lista.curselection()[0]
            del self.tareas[indice]
            self.actualizar_lista()
        except IndexError:
            messagebox.showwarning("Aviso", "Selecciona una tarea.")

    def actualizar_lista(self):
        self.lista.delete(0, tk.END)
        for texto, estado in self.tareas:
            if estado:
                self.lista.insert(tk.END, "✔ " + texto)
            else:
                self.lista.insert(tk.END, "✗ " + texto)


if __name__ == "__main__":
    root = tk.Tk()
    app = AppTareas(root)
    root.mainloop()